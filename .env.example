# Admin AWS credentials — phil-admin IAM user, AdministratorAccess.
# Used by the Phase 1 extract + verify scripts (scripts/extract_sec_edgar.py,
# scripts/verify_bronze_s3_metadata.py, scripts/smoke_test_aws.py).
# Populated when the Admin IAM user is created in session 1.
# Copy this file to .env (gitignored) and fill in real values.
AWS_ACCESS_KEY_ID=AKIA...replace-with-real-access-key
AWS_SECRET_ACCESS_KEY=replace-with-real-secret-key

# dbt runtime AWS credentials — phil-dbt IAM user, scoped to
# lakehouse-dbt-runtime-access policy (iam/lakehouse_dbt_runtime_policy.json).
# Used exclusively by dbt-athena via dbt/profiles.yml. Phase 2 onwards.
# Populated when the phil-dbt IAM user is created in Phase 2 session 1.
AWS_DBT_ACCESS_KEY_ID=AKIA...replace-with-real-access-key
AWS_DBT_SECRET_ACCESS_KEY=replace-with-real-secret-key

# AWS region — locked at the S3 bucket creation step
AWS_DEFAULT_REGION=us-east-1

# Project S3 bucket name — locked at the S3 bucket creation step
S3_BUCKET_NAME=replace-with-actual-bucket-name

# SEC EDGAR User-Agent — required by SEC policy on every request.
# Locked value below (PROJECT_PLAN.md section 4, decision #8).
# Not a secret — included as a default rather than a placeholder.
SEC_EDGAR_USER_AGENT=Phil <pheluciam@outlook.com>
