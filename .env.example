# AWS credentials — populated when the Admin IAM user is created in session 1.
# Copy this file to .env (gitignored) and fill in real values.
AWS_ACCESS_KEY_ID=AKIA...replace-with-real-access-key
AWS_SECRET_ACCESS_KEY=replace-with-real-secret-key

# AWS region — locked at the S3 bucket creation step
AWS_DEFAULT_REGION=us-east-1

# Project S3 bucket name — locked at the S3 bucket creation step
S3_BUCKET_NAME=replace-with-actual-bucket-name

# SEC EDGAR User-Agent — required by SEC policy on every request.
# Locked value below (PROJECT_PLAN.md section 4, decision #8).
# Not a secret — included as a default rather than a placeholder.
SEC_EDGAR_USER_AGENT=Phil <pheluciam@outlook.com>
