# Python build + bytecode artefacts
__pycache__/
*.py[cod]
*$py.class

# Virtual environments — rebuilt from requirements.txt, never committed
.venv/
venv/
env/
ENV/

# Secrets — NEVER commit. Use .env.example as the committed template.
.env
.env.local
*.pem
*.key

# AWS local credential cache — we authenticate via .env, not via ~/.aws/
.aws/

# Linter / type-checker / test caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Jupyter checkpoint dirs
.ipynb_checkpoints/

# IDE / editor scratch
.vscode/
.idea/
*.swp
*.swo

# OS-level junk
.DS_Store
Thumbs.db
desktop.ini

# Local data scratch — bronze / silver / gold live on S3, not in the repo
data/
output/
scratch/
