# Python build + bytecode artefacts
__pycache__/
*.py[cod]
*$py.class

# Virtual environments — rebuilt from requirements.txt, never committed
.venv/
venv/
env/
ENV/

# Secrets — NEVER commit. Use .env.example as the committed template.
.env
.env.local
*.pem
*.key

# AWS local credential cache — we authenticate via .env, not via ~/.aws/
.aws/

# Linter / type-checker / test caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Jupyter checkpoint dirs
.ipynb_checkpoints/

# IDE / editor scratch — exclude .vscode/ runtime junk but un-ignore the
# two project-shared config files (standard portfolio-repo convention).
.vscode/*
!.vscode/settings.json
!.vscode/dbt_project.permissive.schema.json
.idea/
*.swp
*.swo

# OS-level junk
.DS_Store
Thumbs.db
desktop.ini

# Local data scratch — bronze / silver / gold live on S3, not in the repo
data/
output/
scratch/

# dbt — local-only runtime artefacts. profiles.yml carries env_var() refs
# but is excluded out of an abundance of caution; .example committed instead.
dbt/profiles.yml
dbt/target/
dbt/dbt_packages/
dbt/logs/
